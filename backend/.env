NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/popcorn_cinema

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=popcorn_cinema_access_secret_2026_super_secure
JWT_REFRESH_SECRET=popcorn_cinema_refresh_secret_2026_super_secure
JWT_ACCESS_EXPIRES=8h
JWT_REFRESH_EXPIRES=30d

# OTP
OTP_EXPIRES_MINUTES=10

# Frontend URL
CLIENT_URL=http://localhost:5173

# Seat Lock TTL (seconds)
SEAT_LOCK_TTL=300

# MoMo Mock
MOMO_PARTNER_CODE=MOMO_MOCK
MOMO_ACCESS_KEY=mock_access_key
MOMO_SECRET_KEY=mock_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# ══════════════════════════════════════════════════════════
# 📧 EMAIL OTP  (chọn 1 trong 2, không chọn → dùng Ethereal dev)
# ══════════════════════════════════════════════════════════

# OPTION 1: Resend.com (khuyên dùng - free 3000 email/tháng)
# Đăng ký: https://resend.com → API Keys → tạo key
# Mặc định gửi từ: onboarding@resend.dev (không cần verify domain)
RESEND_API_KEY=

# OPTION 2: Gmail App Password
# Vào: https://myaccount.google.com → Bảo mật → Xác minh 2 bước → Mật khẩu ứng dụng
SMTP_USER=
SMTP_PASS=

# ══════════════════════════════════════════════════════════
# 📱 SMS OTP  (chọn 1, không chọn → OTP hiện trong terminal)
# ══════════════════════════════════════════════════════════

# OPTION 1: ESMS.vn (SMS Việt Nam - rẻ nhất ~500đ/tin)
# Đăng ký: https://esms.vn → Quản lý API
ESMS_API_KEY=
ESMS_SECRET=
ESMS_BRAND_NAME=Popcorn

# OPTION 2: Twilio (quốc tế)
# Đăng ký: https://twilio.com → Console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
