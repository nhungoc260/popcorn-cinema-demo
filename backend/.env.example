# ─────────────────────────────────────────
# POPCORN CINEMA — Backend Environment
# Đổi tên file này thành .env
# ─────────────────────────────────────────

PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/popcorn_cinema

JWT_ACCESS_SECRET=popcorn_access_secret_change_in_prod
JWT_REFRESH_SECRET=popcorn_refresh_secret_change_in_prod

CLIENT_URL=http://localhost:5173

# Redis (optional - fallback to in-memory)
REDIS_URL=redis://localhost:6379

# Google OAuth (same Client ID as frontend)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
