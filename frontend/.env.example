# Popcorn Cinema - Frontend Environment Variables
# Copy file này thành .env và điền giá trị

# Backend API URL
VITE_API_URL=http://localhost:5000/api

# Google OAuth Client ID
# Lấy tại: https://console.cloud.google.com/apis/credentials
# 1. Tạo OAuth 2.0 Client ID
# 2. Authorized JavaScript origins: http://localhost:5173
# 3. Copy "Client ID" vào đây
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
